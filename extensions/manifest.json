{
    "manifest_version": 3,
    "name": "Open in Safari",
    "version": "1.0",
    "description": "在 Safari 浏览器中打开当前页面",
    "permissions": [
        "tabs",
        "nativeMessaging",
        "activeTab"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_title": "在 Safari 中打开",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    }
}